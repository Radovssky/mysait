# =========================================
# Postgres (используется и приложением, и docker-compose)
# =========================================
POSTGRES_USER=mysait
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=mysait

# Локально (приложение запускается через pnpm dev, postgres в docker compose)
DATABASE_URL=postgresql://mysait:replace-me@localhost:5432/mysait

# В production (web и postgres в одной docker-сети, host = имя сервиса)
# DATABASE_URL=postgresql://mysait:replace-me@postgres:5432/mysait

# =========================================
# Auth.js v5
# =========================================
# `openssl rand -base64 32` — пересоздать на проде
AUTH_SECRET=dev-secret-replace-in-prod

# Полный URL сайта (https в проде)
NEXTAUTH_URL=http://localhost:3000

# Креды админа — сид в БД через scripts/seed-admin.ts
ADMIN_EMAIL=
# bcrypt-хеш пароля (`pnpm tsx scripts/hash-password.ts <pwd>`).
# ВАЖНО: оборачивайте в одинарные кавычки — bcrypt-хеш содержит $-символы,
# которые иначе интерполирует bash при `source .env` в скриптах бэкапов.
ADMIN_PASSWORD_HASH=''

# =========================================
# Caddy (профиль `prod` в docker-compose.yml)
# =========================================
# Хост для Caddy:
#   - локально: ":80" (HTTP без TLS)
#   - на проде: "mysait.example.com" (автоматически HTTPS через Let's Encrypt)
CADDY_HOST=:80
# Почта для Let's Encrypt (на проде — реальная)
CADDY_ACME_EMAIL=dev@example.com

# Абсолютный URL сайта для metadata / OG / sitemap. На проде = https://<домен>.
SITE_URL=http://localhost:3000

# =========================================
# Uploads
# =========================================
# Где хранить картинки. Default:
# - dev: ./uploads (в корне проекта, в .gitignore)
# - production: /var/data/uploads (монтируется как docker volume)
# UPLOADS_DIR=/var/data/uploads
